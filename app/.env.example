# ─────────────────────────────────────────────────────────────
# Coach S'investir IA — fournisseurs optionnels.
# Sans aucune clé, le coach fonctionne en mode "mock" déterministe
# et la voix utilise la synthèse du navigateur (Web Speech). La démo marche toujours.
# Priorité du conseil : OpenAI > Groq > mock.
# ─────────────────────────────────────────────────────────────

# OpenAI — conseil (GPT) ET voix neuronale (TTS), avec UNE seule clé.
# Clé : https://platform.openai.com/api-keys (facturation API séparée de l'abo ChatGPT).
OPENAI_API_KEY=
# Modèle de conseil — gamme 2026. gpt-5.4-mini : rapide, bon FR, peu cher.
# Alternatives : gpt-5.4 (meilleur), gpt-5.5 (flagship), gpt-5.4-nano (ultra cheap).
# NB : la gamme GPT-5 utilise max_completion_tokens (géré par la route).
OPENAI_MODEL=gpt-5.4-mini
# Voix (endpoint /v1/audio/speech) : tts-1-hd (qualité) ou tts-1 (latence).
# Voix dispo : alloy, ash, coral, echo, fable, onyx, nova, sage, shimmer.
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy

# Groq — alternative gratuite pour le conseil (texte uniquement, pas de voix fr).
# Clé : https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
